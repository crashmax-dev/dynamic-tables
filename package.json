{
  "name": "dynamic-tables",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run /^dev:.*/",
    "dev:frontend": "vite",
    "dev:backend": "node --env-file=.env --watch ./api/main.ts",
    "type-check": "pnpm run /^type-check:.*/",
    "type-check:frontend": "vue-tsc --noEmit --project tsconfig.app.json",
    "type-check:backend": "tsc --noEmit --project tsconfig.node.json",
    "build": "vite build",
    "preview": "vite preview",
    "openapi": "openapi-ts",
    "lint": "eslint . --cache",
    "lint:fix": "eslint . --fix --cache",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "repomix": "repomix",
    "prebuild": "pnpm type-check"
  },
  "dependencies": {
    "@hono/node-server": "1.19.12",
    "@hono/zod-openapi": "1.2.4",
    "@pinia/colada": "1.1.0",
    "@scalar/hono-api-reference": "0.10.6",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/vue-table": "8.21.3",
    "@tanstack/vue-virtual": "3.13.23",
    "@vueuse/core": "14.2.1",
    "@vueuse/router": "14.2.1",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "drizzle-kit": "0.31.10",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.10",
    "lucide-vue-next": "1.0.0",
    "pg": "8.20.0",
    "pinia": "3.0.4",
    "reka-ui": "2.9.3",
    "tailwind-merge": "3.5.0",
    "tailwindcss": "4.2.2",
    "vue": "3.5.32",
    "vue-router": "5.0.4",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "7.4.3",
    "@hey-api/openapi-ts": "0.95.0",
    "@types/node": "24.12.0",
    "@types/pg": "8.20.0",
    "@vitejs/plugin-vue": "6.0.5",
    "@vue/tsconfig": "0.9.1",
    "eslint": "9.39.4",
    "eslint-plugin-format": "2.0.1",
    "eslint-plugin-pinia": "0.4.2",
    "prettier-plugin-css-order": "2.2.0",
    "repomix": "1.13.1",
    "sass-embedded": "1.99.0",
    "shadcn-vue": "2.5.1",
    "tw-animate-css": "1.4.0",
    "typescript": "6.0.2",
    "vite": "8.0.3",
    "vue-tsc": "3.2.6"
  }
}
